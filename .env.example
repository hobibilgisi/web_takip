# Mail Ayarları
# Bu dosyayı .env olarak kopyalayın ve kendi bilgilerinizle doldurun

# Gönderen mail adresi (örn: senin@gmail.com)
SENDER_EMAIL=

# Gmail için Uygulama Şifresi (16 haneli)
# https://myaccount.google.com/apppasswords adresinden alın
SENDER_PASSWORD=

# Bildirim gönderilecek mail adresi
NOTIFY_EMAIL=
